<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<!--이 XML이 어떤 자바 인터페이스와 짝인지 지정. CategoryRepository 인터페이스의 풀 경로를 그대로 적음 -->
<mapper namespace="com.study.category.repository.CategoryRepository">
  <!-- 카테고리 전체 목록 조회 -->
  <select id="getCategories" resultType="com.study.category.entity.CategoryEntity">
    SELECT id, name
    FROM category
  </select>
</mapper>
